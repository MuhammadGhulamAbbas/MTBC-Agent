# Voice AI Patient Registration — copy to `.env`. Do not commit `.env`.

# Public URL of this API (Vapi webhooks, links)
PUBLIC_URL=https://your-app.railway.app

# Database (PostgreSQL on Railway or SQLite for local dev)
# Railway’s variable is often postgres://… — the app rewrites it to postgresql+asyncpg:// automatically.
# Use the private DATABASE_URL from the Postgres service. TLS is enabled for non-localhost hosts.
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL=sqlite+aiosqlite:///./patients.db
# Local Postgres without SSL: DATABASE_SSL=0
# Seconds to wait when opening a TCP connection to Postgres (default 25).
# DATABASE_CONNECT_TIMEOUT=25

# Groq (LLM)
GROQ_API_KEY=

# Vapi (telephony / voice platform)
VAPI_API_KEY=
# VAPI_WEBHOOK_SECRET=  # if you verify signatures

# Optional
# LOG_LEVEL=info
