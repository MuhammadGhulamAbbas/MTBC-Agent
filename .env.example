# Voice AI Patient Registration — copy to `.env`. Do not commit `.env`.

# Public URL of this API (Vapi webhooks, links)
PUBLIC_URL=https://your-app.railway.app

# Database (PostgreSQL on Railway or SQLite for local dev)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL=sqlite+aiosqlite:///./patients.db

# Groq (LLM)
GROQ_API_KEY=

# Vapi (telephony / voice platform)
VAPI_API_KEY=
# VAPI_WEBHOOK_SECRET=  # if you verify signatures

# Optional
# LOG_LEVEL=info
